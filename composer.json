{
    "name": "amin/audit-log-pro",
    "description": "Enterprise activity and audit logging plugin for WordPress.",
    "type": "wordpress-plugin",
    "keywords": [
        "wordpress",
        "audit",
        "logging",
        "security"
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-coding-standards/wpcs": "^3.0",
        "squizlabs/php_codesniffer": "^3.9",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "phpstan/phpstan": "^2.2",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-phpunit/wp-phpunit": "dev-master",
        "php-stubs/wordpress-stubs": "dev-master",
        "php-stubs/woocommerce-stubs": "^3.8",
        "yoast/phpunit-polyfills": "^3.0",
        "brain/monkey": "^2.0@dev"
    },
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Amin\\AuditLogPro\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Al Amin",
            "email": "hmalaminmb4@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "lint:fix": "vendor/bin/phpcbf",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit -c phpunit.unit.xml.dist --testsuite=Unit",
        "test:integration": "vendor/bin/phpunit -c phpunit.xml.dist --testsuite=Integration",
        "qa": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}
